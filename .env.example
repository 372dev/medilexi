# Medi Lexi server-side configuration.
#
# NAMES ONLY - this file is committed. Never put a real value here.
# Set the real values in the Vercel dashboard (Settings -> Environment Variables)
# and, for local work, in `.env.local`, which git ignores.
#
# The site runs fine with all of these unset: the API returns 503 and nothing
# else on the site changes. Set them when you are ready to accept submissions.

# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
# Dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=

# Supabase SERVICE ROLE key. Bypasses row-level security, so it is server-only.
# Never prefix it with NEXT_PUBLIC_, never reference it from a client component.
# Dashboard -> Project Settings -> API -> service_role (click "Reveal")
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret gating the internal French-review form. Any long random string;
# generate one with: openssl rand -base64 32
REVIEW_KEY=
